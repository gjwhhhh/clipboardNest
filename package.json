{
  "name": "clipboard-manager",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "start": "tauri dev",
    "start:log": "RUST_LOG=info tauri dev",
    "start:debug": "RUST_LOG=debug tauri dev",
    "stop": "pkill -f clipboard-manager || true",
    "build:release": "tauri build",
    "build:macos": "tauri build --bundles app,dmg",
    "build:macos:release": "tauri build --bundles app,dmg",
    "build:windows": "node scripts/build-windows.mjs",
    "build:windows:host": "tauri build --bundles msi,nsis",
    "build:windows:cross": "tauri build --bundles nsis --runner cargo-xwin --target x86_64-pc-windows-msvc",
    "build:windows:nsis-cross": "tauri build --bundles nsis --runner cargo-xwin --target x86_64-pc-windows-msvc",
    "build:linux": "tauri build --bundles deb,appimage,rpm",
    "test": "cd src-tauri && cargo test",
    "test:watch": "cd src-tauri && cargo test -- --nocapture",
    "test:frontend": "vitest run",
    "test:frontend:watch": "vitest",
    "test:frontend:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "cd src-tauri && cargo clean"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-global-shortcut": "^2.0.0",
    "i18next": "^23.10.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-i18next": "^14.1.0",
    "react-virtuoso": "^4.7.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "happy-dom": "^20.10.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^3.2.6"
  }
}
